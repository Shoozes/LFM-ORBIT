# Copy to .env for local runs. The launchers load this file automatically.

# Default cold-start mode. The app falls back locally if SimSat is absent and
# avoids direct external API calls unless explicitly enabled below.
OBSERVATION_PROVIDER=simsat_sentinel
SIMSAT_ENABLED=false
SIMSAT_DATA_SOURCE=sentinel
SIMSAT_BASE_URL=http://localhost:8080
SIMSAT_TIMEOUT=30

# Optional: use SimSat's Mapbox endpoint.
# OBSERVATION_PROVIDER=simsat_mapbox
# SIMSAT_DATA_SOURCE=mapbox
MAPBOX_ACCESS_TOKEN=

# Optional direct providers.
SENTINEL_CLIENT_ID=
SENTINEL_CLIENT_SECRET=
NASA_API_KEY=
GEE_API_KEY=
GEE_CLIENT_ID=

# Optional local model fetch override.
LFM_MODEL_URL=

# Optional Depth Anything V3 geometry lane. Disabled by default so local/CI
# runs do not require the heavyweight optional package or model artifacts.
DEPTH_ANYTHING_V3_ENABLED=false
DEPTH_ANYTHING_V3_MODEL=depth-anything/da3-large
DEPTH_ANYTHING_V3_DEVICE=auto
DEPTH_ANYTHING_V3_MAX_PIXELS=1048576

# Development/test controls.
DISABLE_EXTERNAL_APIS=true
RESET_RUNTIME_STATE_ON_BOOT=false
VITE_API_BASE_URL=http://127.0.0.1:8000
