{
  "name": "lfm-orbit-frontend",
  "private": true,
  "version": "0.4.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "test:e2e": "npx playwright test",
    "demo:record": "npx playwright test -c playwright.demo.config.ts e2e/demos",
    "demo:showcase": "npx playwright test -c playwright.demo.config.ts e2e/demos/showcase.demo.spec.ts",
    "demo:payload": "npx playwright test -c playwright.demo.config.ts e2e/demos/payload-reduction.demo.spec.ts",
    "demo:tutorial": "npx playwright test e2e/tutorial_video.spec.ts",
    "demo:report": "npx playwright show-report"
  },
  "dependencies": {
    "maplibre-gl": "^5.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/geojson": "^7946.0.14",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.2",
    "vite": "^8.0.9"
  }
}
